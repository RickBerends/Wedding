---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { content, LOCALES } from '../../content/i18n.js';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = content[lang];
const tr = t.travel;
---
<BaseLayout lang={lang} slug="travel" title={tr.title}>
  <section class="wrap page-hero">
    <p class="eyebrow">{t.brand}</p>
    <Icon name="car" class="art" />
    <h1>{tr.title}</h1>
    <p class="quote">“{tr.quote}”</p>
  </section>
  <section class="wrap">
    <div class="stack">
      {tr.blocks.map((b) => (
        <article class="block">
          <h2>{b.h}</h2>
          <p>{b.p}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
