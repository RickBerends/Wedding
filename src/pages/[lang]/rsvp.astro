---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Illustration from '../../components/Illustration.astro';
import { content, LOCALES } from '../../content/i18n.js';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = content[lang];
const r = t.rsvp;
---
<BaseLayout lang={lang} slug="rsvp" title={r.title}>
  <section class="midnight">
    <div class="wrap page-hero">
      <p class="eyebrow">{t.brand}</p>
      <!-- Section title set on an arc, with a spinning disco ball -->
      <svg class="art" viewBox="0 0 300 150" style="width:min(24rem,82%);color:var(--chrome)" aria-hidden="true">
        <defs><path id="arc" d="M20 118 A150 150 0 0 1 280 118" /></defs>
        <text font-family="Helvetica Neue, Arial, sans-serif" font-weight="900" font-size="40" letter-spacing="1" fill="currentColor">
          <textPath href="#arc" startOffset="50%" text-anchor="middle">{r.title.toUpperCase()}</textPath>
        </text>
        <g class="spin" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" fill="none"
           style="transform-box:fill-box;transform-origin:center" transform="translate(150 116)">
          <circle r="15" /><path d="M-15 0h30M0-15v30M-10-10c6 4 14 4 20 0M-10 10c6-4 14-4 20 0" />
        </g>
      </svg>
      <h1>{r.title}</h1>
      <p class="quote rsvp-intro">{r.intro}</p>
      <Illustration src="img/ducks.jpg" alt="Two ducks in wedding outfits toasting under a disco ball" class="page-art" />
    </div>

    <div class="wrap">
      <div class="rsvp-grid">
        <div>
          <p class="deadline">{r.deadline}</p>
        </div>
        <form class="form" action="#" method="post" aria-label={r.title}>
          <label>
            {r.nameLabel}
            <input type="text" name="name" autocomplete="name" required />
          </label>

          <div class="opts" role="radiogroup" aria-label={r.title}>
            {r.options.map((o, i) => (
              <label class="opt">
                <input type="radio" name="attending" value={o.value} required={i === 0} />
                <span>{o.label}</span>
              </label>
            ))}
          </div>

          <label>
            {r.guestsLabel}
            <input type="number" name="guests" min="1" max="20" inputmode="numeric" />
          </label>
          <label>
            {r.dietaryLabel}
            <textarea name="dietary" rows="2"></textarea>
          </label>
          <label id="song">
            {r.songLabel}
            <input type="text" name="song" />
          </label>

          <button class="send" type="submit">{r.submit}</button>
          <p class="backend-note">{r.backendNote}</p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
