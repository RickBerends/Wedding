---
import { path } from '../lib/url.js';
import { DEFAULT_LOCALE } from '../content/i18n.js';
const to = path(DEFAULT_LOCALE, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${to}`} />
    <link rel="canonical" href={to} />
    <title>Rick &amp; Jikke</title>
  </head>
  <body>
    <p>Redirecting to <a href={to}>Rick &amp; Jikke</a>…</p>
  </body>
</html>
