---
// Original line-art icons drawn in the reference style. `currentColor` so they
// work on both the paper and midnight themes. Not derived from the Pinterest images.
interface Props { name: string; class?: string; }
const { name, class: className = 'art' } = Astro.props;
const common = {
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '3',
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
  'aria-hidden': 'true',
};
---
{name === 'toast' && (
  <svg class={className} viewBox="0 0 320 150" {...common}>
    <path d="M96 128c-20 0-34-2-34-2M120 128c14 0 20-2 20-2" />
    <path d="M104 122V86" />
    <path d="M78 40c0 20 12 32 26 32s26-12 26-32z" />
    <path d="M78 40h52" /><path d="M84 52c8 4 30 4 40 0" />
    <path d="M216 122V86" />
    <path d="M190 40c0 20 12 32 26 32s26-12 26-32z" />
    <path d="M190 40h52" /><path d="M196 52c8 4 30 4 40 0" />
    <path d="M200 128c-14 0-20-2-20-2M224 128c20 0 34-2 34-2" />
    <path d="M130 44l60-2" />
    <path d="M150 20l-4 12M168 18l2 12M158 12v12" stroke-width="2.6" />
  </svg>
)}
{name === 'rings' && (
  <svg class={className} viewBox="0 0 60 60" {...common}>
    <circle cx="23" cy="34" r="15" /><circle cx="39" cy="30" r="13" />
    <path d="M39 17l-3-6 3-5 3 5-3 6z" />
  </svg>
)}
{name === 'disco' && (
  <svg class={className} viewBox="0 0 60 62" {...common} stroke-width="2.6">
    <path d="M30 10V4" />
    <g class="spin" style="transform-box:fill-box;transform-origin:center">
      <circle cx="30" cy="32" r="18" />
      <path d="M12 32h36M30 14v36M16 20c8 5 20 5 28 0M16 44c8-5 20-5 28 0M18 24c6-8 18-8 24 0M18 40c6 8 18 8 24 0" />
    </g>
  </svg>
)}
{name === 'car' && (
  <svg class={className} viewBox="0 0 60 54" {...common} stroke-width="2.8">
    <path d="M8 40h40M10 40l4-11h26l6 11M18 29l2-7h12l3 7" />
    <circle cx="19" cy="43" r="4" /><circle cx="39" cy="43" r="4" />
    <path d="M48 34c4-1 7 1 7 4s-3 5-7 4" stroke-dasharray="1 4" />
  </svg>
)}
{name === 'coupes' && (
  <svg class={className} viewBox="0 0 60 56" {...common} stroke-width="2.8">
    <path d="M14 12c0 9 5 15 11 15s11-6 11-15zM25 27v18M18 46h14" />
    <path d="M46 16c0 8-4 13-9 13" /><path d="M28 20l14-2" />
  </svg>
)}
{name === 'question' && (
  <svg class={className} viewBox="0 0 60 60" {...common} stroke-width="2.8">
    <path d="M22 24c0-6 4-10 9-10s9 3 9 9c0 6-8 6-8 13" />
    <circle cx="32" cy="46" r="1.6" fill="currentColor" />
    <path d="M12 14l2 4 4 2-4 2-2 4-2-4-4-2 4-2zM48 40l1.5 3 3 1.5-3 1.5-1.5 3-1.5-3-3-1.5 3-1.5z" />
  </svg>
)}
{name === 'sparkle' && (
  <svg class={className} viewBox="0 0 60 60" {...common} stroke-width="2.6">
    <path d="M30 10c0 12 8 20 20 20-12 0-20 8-20 20 0-12-8-20-20-20 12 0 20-8 20-20z" />
  </svg>
)}
{name === 'bed' && (
  <svg class={className} viewBox="0 0 60 44" {...common} stroke-width="2.8">
    <path d="M8 12v28M8 26h44v14M52 30v10" />
    <path d="M15 26v-6h14v6" />
    <path d="M8 33h44" />
  </svg>
)}
{name === 'lodge' && (
  <svg class={className} viewBox="0 0 64 56" {...common} stroke-width="2.8">
    <path d="M8 47H56" />
    <path d="M14 28L30 14L46 28" />
    <path d="M18 27V47" /><path d="M42 27V47" />
    <path d="M27 47V36H33V47" />
    <path d="M35 31H40V36H35Z" />
    <path d="M52 9a8 8 0 1 0 4 13 6 6 0 1 1-4-13Z" />
    <path d="M11 13l1 3 3 1-3 1-1 3-1-3-3-1 3-1z" stroke-width="2" />
    <path d="M45 11l.8 2.4 2.4.8-2.4.8-.8 2.4-.8-2.4-2.4-.8 2.4-.8z" stroke-width="2" />
  </svg>
)}
{name === 'note' && (
  <svg class={className} viewBox="0 0 60 60" {...common} stroke-width="2.8">
    <path d="M25 45V17l19-5v27" />
    <circle cx="18" cy="45" r="7" /><circle cx="37" cy="39" r="7" />
  </svg>
)}
{name === 'palette' && (
  <svg class={className} viewBox="0 0 60 60" {...common} stroke-width="2.6">
    <path d="M30 8C17 8 6 17 6 30c0 9 7 15 15 15 4 0 6-2 6-5 0-2-2-3-2-6 0-3 2-5 6-5h7c8 0 10-6 10-11C48 15 41 8 30 8z" />
    <circle cx="19" cy="26" r="2.4" fill="currentColor" stroke="none" />
    <circle cx="29" cy="19" r="2.4" fill="currentColor" stroke="none" />
    <circle cx="40" cy="24" r="2.4" fill="currentColor" stroke="none" />
  </svg>
)}
